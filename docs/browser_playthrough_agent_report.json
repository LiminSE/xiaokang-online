  "dialogueReads": [
    {
      "context": "player_intro",
      "speaker": "旁白",
      "text": "旁白：抽卡停在我早已麻痹。\n茶室值班表闪了一下，像在确认本人上线。"
    },
    {
      "context": "player_intro",
      "speaker": "你",
      "text": "多发点"
    },
    {
      "context": "player_intro",
      "speaker": "你",
      "text": "先逛，正事自己会露头。"
    },
    {
      "context": "player_intro",
      "speaker": "旁白",
      "text": "旁白：没有宏大宣言，只有一条很像群聊的开场。"
    },
    {
      "context": "player_intro",
      "speaker": "你",
      "text": "？"
    },
    {
      "context": "player_intro",
      "speaker": "旁白",
      "text": "旁白：你决定先听听小镇怎么接话。"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "旁白",
      "text": "旁白：弧形反叛超量🐉刚上线，\n龙牌馆的龙角裁判席先亮了一下。"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "别让它掉地上"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "你",
      "text": "那我认真问一句：现在从哪条线开始比较不会绕晕？"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "你",
      "text": "那正事怎么走？"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "额外牌堆那边，先过去别急。"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "这是你"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "你",
      "text": "行，比任务提示像人话。"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "现在最该盯的是「小镇中心物件会自己找镜头」。\n进入小镇中心，确认这里今天哪件物件最想出道。\n别把它当跑腿，这是小镇在给你塞分镜。"
    },
    {
      "context": "main_quest_01:talk:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "我先看颜色和构图，谁把气氛调歪了，\n我一眼就能抓到。\n我一接话，旁边的人就会自动入场，\n像片尾彩蛋突然续了三分钟。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近喷泉弹幕井，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_1",
      "speaker": "你",
      "text": "在线回声到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_1",
      "speaker": "青山照",
      "text": "喷泉里不是水，是未读消息。\n它每喷一下，旁边路灯就替大家补一句“确实”。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_2",
      "speaker": "旁白",
      "text": "旁白：你靠近小康钟，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_2",
      "speaker": "你",
      "text": "星砂到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_01:interact:town_center_interact_2",
      "speaker": "青山照",
      "text": "钟声听起来很庄重，直到它把尾音拐成了群聊提示音。"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "你这也太会挑时间"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "你",
      "text": "收到。\n先把频道调到闲聊档，正事让它在旁边排队。"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "你",
      "text": "那我认真问一句：现在从哪条线开始比较不会绕晕？"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "你",
      "text": "那正事怎么走？"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "额外牌堆那边，先过去别急。"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "这是你"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "你",
      "text": "行，比任务提示像人话。"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "现在最该盯的是「小镇中心支线别装路过」。\n进入小镇中心，确认这里今天哪件物件最想出道。\n别把它当跑腿，这是小镇在给你塞分镜。"
    },
    {
      "context": "main_quest_01:return:role_001",
      "speaker": "弧形反叛超量🐉",
      "text": "我先看颜色和构图，谁把气氛调歪了，\n我一眼就能抓到。\n我一接话，旁边的人就会自动入场，\n像片尾彩蛋突然续了三分钟。"
    },
    {
      "context": "main_quest_02:interact:restaurant_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近晚饭召集锅，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_02:interact:restaurant_interact_1",
      "speaker": "你",
      "text": "晚饭票根到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_02:interact:restaurant_interact_1",
      "speaker": "Hxr",
      "text": "锅盖一掀，蒸汽先喊了一句集合。\n很怪，但饭点就是有这种统治力。"
    },
    {
      "context": "main_quest_02:interact:dragon_card_house_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近无效门禁，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_02:interact:dragon_card_house_interact_1",
      "speaker": "你",
      "text": "牌面碎片到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_02:interact:dragon_card_house_interact_1",
      "speaker": "弧形反叛超量🐉",
      "text": "门禁努力讲规则，门框努力装听懂，\n牌桌努力假装这不是日常。"
    },
    {
      "context": "main_quest_03:interact:livehouse_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近深夜灯控台，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_03:interact:livehouse_interact_1",
      "speaker": "你",
      "text": "灯控便签到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_03:interact:livehouse_interact_1",
      "speaker": "赛博鳏夫",
      "text": "灯控台一滑，舞台立刻出现“明明没人点歌却已经高潮\n”的效果。"
    },
    {
      "context": "main_quest_03:interact:echo_lake_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近漂流诗页，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_03:interact:echo_lake_interact_1",
      "speaker": "你",
      "text": "漂流诗页到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_03:interact:echo_lake_interact_1",
      "speaker": "Hxr",
      "text": "诗页漂着漂着开始押韵，湖面选择已读不回。"
    },
    {
      "context": "main_quest_04:interact:atelier_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近同步色板，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_04:interact:atelier_interact_1",
      "speaker": "你",
      "text": "色板芯片到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_04:interact:atelier_interact_1",
      "speaker": "NNZ",
      "text": "色板转了一圈，最后选了一个“看不懂但很对味”的颜\n色。"
    },
    {
      "context": "main_quest_04:interact:northern_wilds_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近野外信号塔，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_04:interact:northern_wilds_interact_1",
      "speaker": "你",
      "text": "信号叶片到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_04:interact:northern_wilds_interact_1",
      "speaker": "很复杂",
      "text": "塔顶亮了一下，像有人终于把消息发出去了。"
    },
    {
      "context": "main_quest_05:interact:server_room_interact_1",
      "speaker": "旁白",
      "text": "旁白：你靠近缓存清理台，它立刻亮了一下，\n像终于等到有人点它。"
    },
    {
      "context": "main_quest_05:interact:server_room_interact_1",
      "speaker": "你",
      "text": "缓存扫帚到手。\n这个物件明显比说明书会说话。"
    },
    {
      "context": "main_quest_05:interact:server_room_interact_1",
      "speaker": "夜处理炼金师",
